DATABASE_URL="mysql://d4sign_bitrix:d4sign_bitrix@127.0.0.1:3306/d4sign_bitrix?allowPublicKeyRetrieval=true"

# URL pública HTTPS do ngrok (install, robôs, webhooks)
PUBLIC_APP_URL="https://seu-subdominio.ngrok-free.app"

PORT=3001

# ----- Bitrix24 -----
BITRIX_APP_ID=""
BITRIX_APP_SECRET=""

# ----- HubSpot (Developer Platform — hubspot-app/ + hs project upload) -----
HUBSPOT_CLIENT_ID=""
HUBSPOT_CLIENT_SECRET=""
# URL pública do painel (iframe settings); dev: http://localhost:3002
# HUBSPOT_WEB_PUBLIC_URL="http://localhost:3002"
# Legacy Public Apps apenas (deprecated):
# HUBSPOT_APP_ID=""
# HUBSPOT_DEVELOPER_API_KEY=""
# Escopos OAuth (opcional — default já cobre deals/contacts/companies/files)
# HUBSPOT_SCOPES="crm.objects.deals.read crm.objects.deals.write crm.objects.contacts.read crm.objects.companies.read files oauth"

# ----- Feature flags -----
USE_PRISMATIC_BRIDGE="false"
ENABLE_D4SIGN_API="true"

# ----- D4Sign -----
# Override da URL base D4Sign (padrão: https://secure.d4sign.com.br/api/v1)
# D4SIGN_API_BASE_URL="https://secure.d4sign.com.br/api/v1"

# ----- CORS: frontends locais -----
# Adicione mais origens separadas por vírgula conforme necessário
CORS_ORIGINS="http://127.0.0.1:3000,http://localhost:3000,http://127.0.0.1:3002,http://localhost:3002"
