# =============================================================================
# d4sign-api — variáveis de produção
# Copie para .env.production e preencha os valores reais
# =============================================================================

# ----- Banco de dados (MySQL) -----
DATABASE_URL="mysql://d4sign_bitrix:SENHA_FORTE@127.0.0.1:3306/d4sign_bitrix?allowPublicKeyRetrieval=true"

# Usadas pelo docker-compose.prod.yml
MYSQL_ROOT_PASSWORD=root_senha_forte
MYSQL_DATABASE=d4sign_bitrix
MYSQL_USER=d4sign_bitrix
MYSQL_PASSWORD=SENHA_FORTE

# ----- API -----
PUBLIC_APP_URL="https://api.SEU_DOMINIO.com"
PORT=3003

# ----- Bitrix24 -----
BITRIX_APP_ID="local.xxxxxxxxxxxxxxxx"
BITRIX_APP_SECRET="xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# ----- Feature flags -----
USE_PRISMATIC_BRIDGE="false"
ENABLE_D4SIGN_API="false"

# ----- CORS: adicione a URL do Vercel + domínio customizado -----
CORS_ORIGINS="https://SEU_APP.vercel.app,https://app.SEU_DOMINIO.com"
